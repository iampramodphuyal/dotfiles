alias urldecode='node -e "console.log(decodeURIComponent(process.argv[1]))"'
alias pnvim='pipenv shell nvim .'
alias base64encode='python ~/dotfiles/alias/base64/base64_ops.py encode'
alias base64decode='python ~/dotfiles/alias/base64/base64_ops.py decode'
alias strlen='node -e "console.log(process.argv[1].length)"'
