# Ignore patterns for stow
# Documentation
^/README\.md
^/README\..*
^/LICENSE.*

# Git files
\.git
\.gitignore
\.gitmodules

# Scripts and installation files
^/scripts
^/Makefile
^/install\.sh

# Root-level .config (not a stow package)
^/\.config

# macOS files
\.DS_Store
^/macos/Brewfile

# Backup and temp files
.*~
\#.*\#
\.swp
\.swo
